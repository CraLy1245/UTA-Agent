SURVIVAL_AGENT_ENV=development
SURVIVAL_AGENT_HOST=127.0.0.1
SURVIVAL_AGENT_PORT=8000
SURVIVAL_AGENT_DATABASE_URL=sqlite:///./data/survival_agent.db
SURVIVAL_AGENT_CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=/api

# Provider credentials are read from the environment only and never stored in SQLite.
OPENAI_API_KEY=
SURVIVAL_AGENT_WORKSPACE_PATH=./workspace
SURVIVAL_AGENT_TOOLS_ENABLED=true
