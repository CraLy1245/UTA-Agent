{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://survival-agent.local/contracts/feedback-event.json",
  "title": "Quality feedback with separate survival reward result",
  "type": "object",
  "required": ["quality_feedback", "survival_reward"],
  "properties": {
    "quality_feedback": {
      "type": "object",
      "required": ["id", "turn_id", "rating", "created_at"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "turn_id": { "type": "string", "format": "uuid" },
        "rating": { "enum": ["satisfied", "unsatisfied"] },
        "comment": { "type": ["string", "null"], "maxLength": 2000 },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "survival_reward": {
      "type": "object",
      "required": ["granted_now", "transactions"],
      "properties": {
        "granted_now": { "type": "boolean" },
        "transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["account_type", "amount_units", "idempotency_key"],
            "properties": {
              "account_type": { "enum": ["read", "output"] },
              "amount_units": { "type": "integer" },
              "idempotency_key": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
