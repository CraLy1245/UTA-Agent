{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://survival-agent.local/contracts/execution-trace.json",
  "title": "Immutable completed turn execution trace",
  "type": "object",
  "required": [
    "id",
    "turn_id",
    "model_id",
    "memory_revision_ids",
    "skill_revision_ids",
    "tool_names",
    "provider_raw_usage",
    "normalized_usage",
    "input_tokens",
    "output_tokens",
    "latency_ms",
    "completion_status",
    "objective_result",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "turn_id": { "type": "string", "format": "uuid" },
    "model_id": { "type": "string" },
    "memory_revision_ids": { "type": "array", "items": { "type": "string" } },
    "skill_revision_ids": { "type": "array", "items": { "type": "string" } },
    "tool_names": { "type": "array", "items": { "type": "string" } },
    "provider_raw_usage": { "type": "array", "items": { "type": "object" } },
    "normalized_usage": { "type": "object" },
    "input_tokens": { "type": "integer", "minimum": 0 },
    "output_tokens": { "type": "integer", "minimum": 0 },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "completion_status": { "const": "completed" },
    "objective_result": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
